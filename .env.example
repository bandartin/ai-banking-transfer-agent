# Prebuilt Banking AI Transfer Agent — Environment Configuration
# Copy this file to .env and fill in the values.

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production-use-a-long-random-string
FLASK_PORT=8000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DATABASE_URL=sqlite:///banking_demo.db

# ── LLM Mode ─────────────────────────────────────────────────────────────────
# Set to "deterministic" (default, no API key needed), "openai", or "anthropic"
LLM_PROVIDER=deterministic

# OpenAI settings (only used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic settings (only used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Business Rules ───────────────────────────────────────────────────────────
# Interbank fee in KRW (applied when source bank != destination bank)
INTERBANK_FEE=500

# OTP threshold: transfers above this amount require a mock OTP
OTP_THRESHOLD=3000000

# Demo OTP code (always valid in demo mode)
DEMO_OTP_CODE=123456

# ── LangSmith (선택) ─────────────────────────────────────────────────────────
# https://smith.langchain.com 에서 API 키 발급
# 설정하면 LangGraph 실행 트레이스가 자동으로 LangSmith에 기록됩니다.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=banking-transfer-agent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Demo User ────────────────────────────────────────────────────────────────
DEMO_USER_ID=1
